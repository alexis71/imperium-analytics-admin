# ─────────────────────────────────────────────────────────
# Imperium Analytics Admin · configuración
# Copiar a .env y rellenar valores reales (nunca commitear .env)
# ─────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3010

# ── Postgres ─────────────────────────────────────────────
# Usuario dedicado ia_admin_user (creado durante setup)
DATABASE_URL="postgresql://ia_admin_user:REPLACE_ME@localhost:5432/ia_admin_db?schema=public"

# ── JWT ──────────────────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET=REPLACE_ME_64_HEX_CHARS
JWT_REFRESH_SECRET=REPLACE_ME_64_HEX_CHARS
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_DAYS=7

# ── MFA (TOTP · Authenticator apps) ──────────────────────
MFA_ISSUER="Imperium Analytics Admin"
MFA_WINDOW=1

# ── Encriptación at-rest ─────────────────────────────────
# Cifra mfaSecret, Module.sharedSecret, Module.apiToken
# Generar con: openssl rand -hex 32
# CRÍTICO: respaldar en 1Password/Bitwarden · rotarlo requiere migración de datos
APP_ENCRYPTION_KEY=REPLACE_ME_32_HEX_CHARS

# ── Emergency MFA override ───────────────────────────────
# Frase memorable sellada en 1Password (usada por scripts/emergency-disable-mfa.js)
EMERGENCY_OVERRIDE_KEY=REPLACE_ME_WITH_MEMORABLE_PHRASE

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5175,http://admin.imperium.local

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=info

# ── Email (reusa misma cuenta Resend que RT) ─────────────
RESEND_API_KEY=
EMAIL_SANDBOX=true
EMAIL_FROM=onboarding@resend.dev
EMAIL_SANDBOX_TO=abraham@muselecom.com
EMAIL_DEV_OVERRIDE_TO=abraham@muselecom.com
EMAIL_BRAND="Imperium Analytics Admin"
APP_URL=http://localhost:5175

# ── Rate limit ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ── Seed super-admin ─────────────────────────────────────
# Password se genera random en el seed y se muestra una sola vez en consola
SEED_SUPERADMIN_EMAIL=alejandro.rodriguez@muselecom.com
SEED_SUPERADMIN_NAME="Alejandro Rodriguez"

# ── N°60-N°61 · C-arch auto-provision + auto-sync ───────
# Admin POST /customers/:id/modules con autoProvision=true → crea HR/CRM tenant
# automáticamente + pulla data desde vertical origen vía /external/*-for-* endpoints.
# Pre-requisitos: cada vertical/core debe estar corriendo + tener su EXTERNAL secret.
# Base URLs (override solo si verticales/cores corren en puertos no default):
KP_URL=http://localhost:3006
RT_URL=http://localhost:3003
NK_URL=http://localhost:3001
SALES_URL=http://localhost:3050
HR_URL=http://localhost:3040
CRM_URL=http://localhost:3060
# Pull secrets (verticales · READ) · copiar desde <vertical>/server/.env
KP_EXTERNAL_READ_SECRET=
RT_EXTERNAL_READ_SECRET=
NK_EXTERNAL_READ_SECRET=
SALES_EXTERNAL_READ_SECRET=
# Push secrets (cores · WRITE) · copiar desde <core>/server/.env
HR_EXTERNAL_WRITE_SECRET=
CRM_EXTERNAL_WRITE_SECRET=
